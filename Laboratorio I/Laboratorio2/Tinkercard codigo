void problema_uno(long dinero) {
    int n = 10;
    long denominaciones[10] = {50000, 20000, 10000, 5000, 2000, 1000, 500, 200, 100, 50};
    long cantidad[10];

    long restante = dinero;

    for (int i = 0; i < n; i++) {
        cantidad[i] = restante / denominaciones[i];
        restante %= denominaciones[i];
    }

    Serial.println("\nDescomposicion:");
    for (int i = 0; i < n; i++) {
        Serial.print(denominaciones[i]);
        Serial.print(": ");
        Serial.println(cantidad[i]);
    }

    if (restante > 0) {
        Serial.print("Faltante: ");
        Serial.println(restante);
    }
}

