long suma_divisores(long num) {
    long suma = 0;
    for (long i = 1; i <= num / 2; i++) {
        if (num % i == 0)
            suma += i;
    }
    return suma;
}

void problema_diecisiete(long n) {
    long suma_total = 0;
    for (long i = 1; i < n; i++) {
        long b = suma_divisores(i);
        if (b != i && b > 0 && suma_divisores(b) == i && i < b) {
            suma_total += i + b;
        }
    }
    Serial.print("El resultado de la suma es: ");
    Serial.println(suma_total);
}

